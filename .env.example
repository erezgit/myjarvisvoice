# My Jarvis Voice runs fully offline with ZERO required configuration.
# Every value below is OPTIONAL — copy to .env only if you want to override.

# Port for the SQLite API server (frontend talks to this).
# API_PORT=3001

# URL of the local Kokoro voice engine the server proxies to.
# VOICE_ENGINE_URL=http://127.0.0.1:8787

# Port the Kokoro engine listens on (engine/kokoro_server.py).
# MYJARVIS_VOICE_PORT=8787

# Override where model files are stored / looked up.
# Default: ~/Library/Application Support/MyJarvisVoice/models (macOS)
# MYJARVIS_MODEL_DIR=/absolute/path/to/models
